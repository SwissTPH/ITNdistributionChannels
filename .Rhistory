group_by(ITNtype, EHT, ITNcampaign, halflife, histITNcov, EIR)%>%
summarise(nUncomp=mean(nUncomp), nSevere=mean(nSevere), nHost=mean(nHost), prevalenceRate=mean(prevalenceRate), nDirDeaths=mean(nDirDeaths) )%>%
mutate(nUncomp=nUncomp/nHost, nSevere=nSevere/nHost,nDirDeaths=nDirDeaths/nHost )
View(mydf)
mydf_control=mydf %>% filter(ITNcampaign=="none")%>%
ungroup()%>%
select(-ITNcampaign, -halflife, -ITNtype)%>%
rename(nUncomp_none=nUncomp,nSevere_none=nSevere,prevalenceRate_none=prevalenceRate, nDirDeaths_none=nDirDeaths)
View(mydf_control)
mydf_CA=mydf %>%
filter(ITNcampaign !="none") %>% left_join(mydf_control)%>%
mutate(nUncomp_averted=nUncomp_none-nUncomp, nSevere_averted=nSevere_none-nSevere, nDirDeaths_averted=nDirDeaths_none-nDirDeaths)
View(mydf_CA)
View(mydf_control)
mydf_control=mydf %>% filter(ITNcampaign=="none")%>%
ungroup()%>%
select(-ITNcampaign, -halflife, -ITNtype, -nHost)%>%
rename(nUncomp_none=nUncomp,nSevere_none=nSevere,prevalenceRate_none=prevalenceRate, nDirDeaths_none=nDirDeaths)
mydf_CA=mydf %>%
filter(ITNcampaign !="none") %>% left_join(mydf_control)%>%
mutate(nUncomp_averted=nUncomp_none-nUncomp, nSevere_averted=nSevere_none-nSevere, nDirDeaths_averted=nDirDeaths_none-nDirDeaths)
View(mydf_CA)
sum_years=function(date_min, date_max, my_age_group="0-5"){
mydf=all_simul_0_merged %>%
ungroup()%>%
filter(age_group==my_age_group)%>%
filter(as.Date(date)<=date_max, as.Date(date)>=date_min)%>%
group_by(ITNtype, EHT, ITNcampaign, halflife, histITNcov, EIR, seed)%>%
summarise(nUncomp=sum(nUncomp), nSevere=sum(nSevere), nHost=mean(nHost), prevalenceRate=mean(prevalenceRate), nDirDeaths=mean(nDirDeaths))%>%
group_by(ITNtype, EHT, ITNcampaign, halflife, histITNcov, EIR)%>%
summarise(nUncomp=mean(nUncomp), nSevere=mean(nSevere), nHost=mean(nHost), prevalenceRate=mean(prevalenceRate), nDirDeaths=mean(nDirDeaths) )%>%
mutate(nUncomp=nUncomp/nHost, nSevere=nSevere/nHost,nDirDeaths=nDirDeaths/nHost )
mydf_control=mydf %>% filter(ITNcampaign=="none")%>%
ungroup()%>%
select(-ITNcampaign, -halflife, -ITNtype, -nHost)%>%
rename(nUncomp_none=nUncomp,nSevere_none=nSevere,prevalenceRate_none=prevalenceRate, nDirDeaths_none=nDirDeaths)
mydf_CA=mydf %>%
filter(ITNcampaign !="none") %>% left_join(mydf_control)%>%
mutate(nUncomp_averted=nUncomp_none-nUncomp, nSevere_averted=nSevere_none-nSevere, nDirDeaths_averted=nDirDeaths_none-nDirDeaths)
mydf_CA_mean=mydf_CA %>%
group_by(ITNtype, ITNcampaign, halflife, histITNcov, EIR)%>%
summarise(nUncomp_averted_mean=mean(nUncomp_averted), nUncomp_averted_up=max(nUncomp_averted), nUncomp_averted_low=min(nUncomp_averted),
nSevere_averted_mean=mean(nSevere_averted), nSevere_averted_up=max(nSevere_averted), nSevere_averted_low=min(nSevere_averted),
nDirDeaths_averted_mean=mean(nDirDeaths_averted), nDirDeaths_averted_up=max(nDirDeaths_averted), nDirDeaths_averted_low=min(nDirDeaths_averted))
return(list("all_cases"=mydf, "cases_averted"=mydf_CA, "cases_averted_mean"=mydf_CA_mean))
}
total_u5_19_21=sum_years(date_min="2019-01-01", date_max="2021-12-31",my_age_group= "0-5")
total_all_19_21=sum_years("2019-01-01", "2021-12-31", my_age_group="0-100")
total_u1_19_21=sum_years("2019-01-01", "2021-12-31",my_age_group= "0-1")
create_barplot_CA_single=function(mydf, myEIR, myhistITNcov , outcome, myage_group){
if( outcome=="nUncomp"){
outcome_name="Uncomplicated episodes"
} else if ( outcome=="nSevere"){
outcome_name="Severe episodes"
} else if ( outcome=="nDirDeaths"){
outcome_name="Deaths"
}
p=mydf$cases_averted_mean %>%
filter(EIR==myEIR, histITNcov==myhistITNcov,  halflife %in% c(1,2,3) )%>%
mutate(halflife=as.factor(halflife),
delivery=factor(as.character(ITNcampaign),
levels=c("mass",
"massU5", "massU5unif",
"contU1", "contU1unif",
"cont6to14", "cont6to14unif"),
labels=c("Mass",
"Mass <5",
"Mass <5\nuniform",
"Continuous <1", "Continuous <1\nuniform",
"Continuous 6-14", "Continuous 6-14\nuniform")))%>%
ggplot()+
geom_bar(aes_string(x="delivery", y=paste0(outcome, "_averted_mean"), fill="delivery", alpha="halflife"), stat="identity", position = "dodge")+
geom_errorbar(aes_string(x="delivery", ymin=paste0(outcome, "_averted_low"), ymax=paste0(outcome, "_averted_up"), color="delivery", alpha="halflife"), stat="identity", position = "dodge")+
scale_fill_manual(values=c("orange", "dodgerblue","dodgerblue","darkblue", "darkblue", "purple", "purple","darkgrey"))+
scale_color_manual(values=c("orange", "dodgerblue","dodgerblue","darkblue", "darkblue", "purple", "purple","darkgrey"))+
scale_alpha_manual(values=c(0.5, 0.75, 1))+
#labs(x="", y=paste0(outcome_name, " episodes averted\nin ",myage_group),  fill="Delivery mechanism", color="Delivery mechanism", alpha="")+
labs(x="", y="",  fill="Delivery mechanism", color="Delivery mechanism", alpha="")+
theme_bw()+
coord_flip() +
ggtitle(paste0(outcome_name, " averted\nin ",myage_group))
return(p)
}
library(cowplot)
create_barplot_CA_3groups=function(myEIR, myhistITNcov , outcome, outcome_name){
pU1=create_barplot_CA_single(mydf=total_u1_19_21, myEIR=myEIR, myhistITNcov=myhistITNcov , outcome=outcome, myage_group = "children <1")
pU5=create_barplot_CA_single(mydf=total_u5_19_21, myEIR=myEIR, myhistITNcov=myhistITNcov , outcome=outcome, myage_group = "children <5")
pall=create_barplot_CA_single(mydf=total_all_19_21, myEIR=myEIR, myhistITNcov=myhistITNcov , outcome=outcome, myage_group = "all ages")
p=plot_grid(pU1+theme(legend.position = "none"), pU5+theme(legend.position = "none"), pall+theme(legend.position = "none"), nrow=1)
ggsave(filename = file.path(experiment_folder, paste0("barplot_", outcome, "_EIR",myEIR,"_histITN",myhistITNcov, ".png")), width=15, height = 8)
return(p)
}
create_barplot_CA_1group=function(mydf,myEIR, myhistITNcov ,myage_group, name){
pU=create_barplot_CA_single(mydf=mydf, myEIR=myEIR, myhistITNcov=myhistITNcov , outcome="nUncomp", myage_group =myage_group)
pS=create_barplot_CA_single(mydf=mydf, myEIR=myEIR, myhistITNcov=myhistITNcov , outcome="nSevere", myage_group = myage_group)
pD=create_barplot_CA_single(mydf=mydf, myEIR=myEIR, myhistITNcov=myhistITNcov , outcome="nDirDeaths", myage_group = myage_group)
