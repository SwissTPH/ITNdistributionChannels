geom_line(aes(color=ITNcampaign,group=interaction(ITNcampaign, is.unif), linetype=is.unif), lwd=1)+
labs(x="Year", y="Total malaria cases in children under 5 (per 1000)", linetype="", fill="Delivery mechanism", color="Delivery mechanism")+
scale_color_manual(values=c("orange", "darkblue", "dodgerblue", "purple", "grey"))+
